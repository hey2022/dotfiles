{
  "layer": "top",
  "position": "top",
  "modules-left": ["group/workspace-group", "niri/window", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "group/hardware",
    "group/controls",
    "group/tray",
    "custom/notification"
  ],
  "custom/drawer": {
    "tooltip": false,
    "format": "’āÖ"
  },
  "group/workspace-group": {
    "orientation": "inherit",
    "modules": ["custom/hostname", "niri/workspaces", "hyprland/workspaces"]
  },
  "group/controls": {
    "orientation": "inherit",
    "modules": ["wireplumber", "backlight"]
  },
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-left-to-right": false
    },
    "modules": ["battery", "cpu", "memory", "temperature"]
  },
  "niri/workspaces": {
    "format": "{name}",
    "format-icons": {
      "active": "’åÆ",
      "default": "’äæ"
    }
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "format": " {icon} ",
    "format-icons": {
      "default": "Ņ«┤"
    }
  },
  "niri/window": {
    "format": "{app_id}"
  },
  "hyprland/window": {
    "format": "{class}",
    "separate-outputs": true
  },
  "custom/hostname": {
    "format": "{}",
    "exec": "hostname",
    "interval": 60
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "player-icons": {
      "default": "ŌÅĖ"
    },
    "status-icons": {
      "paused": "Ō¢Č"
    },
    "dynamic-order": ["title", "artist"],
    "ignored-players": ["firefox"]
  },
  "group/tray": {
    "orientation": "inherit",
    "drawer": {
      "transition-left-to-right": false,
      "click-to-reveal": true
    },
    "modules": ["custom/drawer", "tray"]
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },
  "clock": {
    "interval": 1,
    "format": "{:%H:%M}",
    "format-alt": "{:%Y-%m-%d %H:%M:%S}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "tz_up",
      "on-scroll-down": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "{usage}% ’ŗø",
    "states": {
      "low": 0,
      "medium": 25,
      "high": 50,
      "critical": 75
    }
  },
  "memory": {
    "format": "{}% ’āē",
    "states": {
      "low": 0,
      "medium": 50,
      "high": 75,
      "critical": 95
    }
  },
  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["’ŗŗ", "’ŗŖ", "’ŗē", "’ŗł", "’ŗł"],
    "tooltip": false
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "{percent}% {icon}",
    "format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"]
  },
  "battery": {
    "states": {
      "warning": 50,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ¾░éä",
    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
  },
  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-muted": "Ņ╗©",
    "on-click": "pwvucontrol",
    "format-icons": ["’Ć”", "’Ć¦", "’Ć©"]
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "’éó’æä",
      "none": "’éó",
      "dnd-notification": "’ćĘ’æä",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó’æä",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ’æä",
      "dnd-inhibited-none": "’ćĘ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}
